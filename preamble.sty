\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{preamble}[Preamble]

% ==========================================
% 1. Czcionki i Język (Silnik LuaLaTeX)
% ==========================================
\usepackage{fontspec}
\usepackage[polish]{babel}
\usepackage[autostyle=true]{csquotes}
\usepackage{unicode-math} 

\setmainfont{Libertinus Serif}[
    UprightFont = *-Regular,
    BoldFont = *-Bold,
    ItalicFont = *-Italic
]
\newfontfamily\semiboldfont{Libertinus Serif-Semibold}
\DeclareTextFontCommand{\textsb}{\semiboldfont}

% UWAGA: Jeśli nadal będzie błąd, upewnij się, że plik nazywa się STIXTwoMath.otf w systemie
%\setmathfont{STIXTwoMath.otf} 
\setmathfont{Latin Modern Math}[
    Scale = MatchLowercase,
    StylisticSet = 1
]

% ==========================================
% 2. Typografia i Geometria Obrazu
% ==========================================
\usepackage{microtype} 
\usepackage{setspace}
\onehalfspacing
\raggedbottom

\clubpenalty=10000        
\widowpenalty=10000       
\displaywidowpenalty=10000
\brokenpenalty=10000     

\interlinepenalty=5000   
\predisplaypenalty=10000

\usepackage[shortcuts]{extdash}

\usepackage{enumitem}
\setlist{
    nosep,               % Usuwa odstępy między punktami (bardzo czytelne)
    itemsep=2pt,         % Dodaje minimalny, bezpieczny odstęp
    beginpenalty=10000,  % Blokuje sieroty przed listą
    midpenalty=500       % Pozwala na łamanie w środku listy
}

% ==========================================
% 3. Kolory i Stylistyka KOMA-Script
% ==========================================
\usepackage{xcolor}
\definecolor{pwblue}{RGB}{0, 101, 169} 
\definecolor{darkgray}{RGB}{50, 50, 50}
\definecolor{codebackground}{RGB}{245, 245, 245}

\AtBeginDocument{%
    \addtokomafont{disposition}{\color{pwblue}\sffamily\bfseries}
    \addtokomafont{chapter}{\LARGE}
    \addtokomafont{section}{\Large}
    \addtokomafont{title}{\normalfont\sffamily\bfseries\Huge\color{pwblue}}
    \addtokomafont{subtitle}{\normalfont\sffamily\large\color{darkgray}}
    \addtokomafont{author}{\normalfont\normalsize}
    \addtokomafont{date}{\normalfont\normalsize\color{darkgray}}
}

% ==========================================
% 4. Nagłówki, Stopki i Linki (Kolejność krytyczna!)
% ==========================================
\usepackage[automark, headsepline=0.4pt]{scrlayer-scrpage}
\usepackage{hyperref}
\usepackage[nameinlink]{cleveref} % MUSI być po hyperref
\usepackage{url}

\clearpairofpagestyles
\ihead{\headmark}
\ohead{\pagemark}
\setkomafont{pageheadfoot}{\sffamily\footnotesize}
\setkomafont{pagenumber}{\sffamily\small\bfseries}

\hypersetup{
    colorlinks=true,
    allcolors=black,
    pdfborder={0 0 0},
    pdfpagemode=UseNone,
    pdfstartview=FitH
}

% ==========================================
% 5. Grafika, Listingi i Bibliografia
% ==========================================
\usepackage{graphicx}
\usepackage{float}
%\usepackage{svg}
\usepackage{caption}
\usepackage{subcaption}
\captionsetup{font=small, labelfont={bf,color=pwblue}, margin=10pt}

\usepackage{tikz}
\usetikzlibrary{shapes.geometric, arrows.meta, positioning, calc, fit, backgrounds}

\usepackage{listings}
\lstset{
    backgroundcolor=\color{codebackground},
    basicstyle=\ttfamily\small,
    breaklines=true,
    captionpos=b,
    frame=single,
    rulecolor=\color{darkgray},
    keywordstyle=\color{pwblue}\bfseries,
    commentstyle=\color{gray}
}

\usepackage[backend=biber, style=numeric, maxcitenames=1, mincitenames=1, sorting=none]{biblatex}
\addbibresource{biblio.bib}

\endinput